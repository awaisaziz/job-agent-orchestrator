APP_NAME=Job Agent Orchestrator
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# Provider API keys (backend only)
OPENAI_API_KEY=replace-with-openai-key
ANTHROPIC_API_KEY=replace-with-anthropic-key
GROK_API_KEY=replace-with-grok-key

# Optional provider base URLs
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
GROK_BASE_URL=https://api.x.ai/v1/chat/completions

# LLM routing and reliability
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_DEFAULT_MODEL=gpt-4.1-mini
LLM_ENABLED_MODELS=gpt-4.1-mini,gpt-4o-mini,claude-3-5-sonnet,claude-3-7-sonnet,grok-3-mini,grok-3
